# Configurazione del gateway (copiare in /etc/soltea-gateway/gateway.env, chmod 600).

# Bind in loopback: e' nginx a esporlo sul 443.
GW_HOST=127.0.0.1
GW_PORT=8182

# Token dell'orchestratrice (Claudia). Generane uno robusto: openssl rand -hex 32
GW_ORCH_TOKEN=

# Token per-agente: "agent_id:token" separati da virgola.
#   GW_AGENT_TOKENS=win-dev-01:abc...,win-dev-02:def...
GW_AGENT_TOKENS=

# In alternativa (solo dev/staging): un unico token condiviso per qualsiasi agente.
# GW_SHARED_AGENT_TOKEN=

# File dove vengono persistiti i token creati a runtime via POST /provision
# (l'orchestratrice li crea senza editare questo .env). Deve essere scrivibile
# dall'utente del servizio (soltea-gw). chmod 600 automatico.
GW_AGENT_TOKENS_FILE=/var/lib/soltea-gateway/agent_tokens.json

# Blob store (zip dei ticket).
GW_BLOB_DIR=/var/lib/soltea-gateway/blobs
GW_BLOB_TTL_SECONDS=86400
GW_BLOB_MAX_BYTES=209715200

GW_HEARTBEAT_SECONDS=30
